# ============================================================
# EÄRENDIL — .env.example complet
# ============================================================
# Ce fichier liste les variables configurables par l'application.
# Copie-le vers .env puis adapte les valeurs.
# Les pourcentages sont exprimés en %, pas en ratio.
# Exemple: 1.50 signifie 1,5%.
# ============================================================

# ============================================================
# 1) Runtime / sécurité d'exécution
# ============================================================

# Mode d'exécution:
# - paper : simulation locale avec FakeBroker pour l'exécution.
# - real  : envoie les ordres au broker configuré.
EAR_MODE=paper

# Garde-fou obligatoire pour le mode real.
# Si EAR_MODE=real mais REAL_TRADING_ENABLED=false, le bot doit bloquer les ordres.
REAL_TRADING_ENABLED=false

# Niveau de logs: DEBUG, INFO, WARNING, ERROR.
LOG_LEVEL=INFO

# Délai entre deux boucles complètes du bot.
# Plus bas = bot plus réactif, mais plus d'appels API.
POLL_INTERVAL_SECONDS=60


# ============================================================
# 2) Broker / API eToro
# ============================================================

# Broker utilisé pour les snapshots et l'exécution.
# Valeurs connues: etoro, fake.
BROKER=etoro

# Environnement eToro.
# demo = compte démo ; live/prod selon implémentation future.
ETORO_ENV=demo

# URL de base de l'API eToro.
ETORO_API_BASE_URL=https://public-api.etoro.com

# Clés API eToro. Ne jamais commiter de vraies clés dans Git.
ETORO_API_KEY=replace_me
ETORO_USER_KEY=replace_me


# ============================================================
# 3) Univers de trading
# ============================================================

# Symbole utilisé si WATCHLIST est vide.
DEFAULT_SYMBOL=BTC

# Liste des actifs analysés à chaque boucle.
# Plus elle est longue, plus il y a d'appels API et plus le cycle est lent.
WATCHLIST=BTC,ETH,DOGE,SOL,MSFT,NVDA,AAPL

# Devise de référence pour les ordres.
BASE_CURRENCY=USD

# Stratégie active.
# Valeurs connues: breakout, intraday_trend.
INVESTMENT_STRATEGY=intraday_trend


# ============================================================
# 4) Stratégie breakout historique
# ============================================================
# Cette section n'a d'impact que si INVESTMENT_STRATEGY=breakout.

# Nombre de bougies précédentes utilisées pour détecter une cassure.
BREAKOUT_LOOKBACK=3

# Cassure minimale requise au-dessus du range précédent.
BREAKOUT_MIN_BREAKOUT_PERCENT=0.05

# Si true, exige une bougie verte pour acheter.
BREAKOUT_REQUIRE_GREEN_CANDLE=true

# Position de clôture minimale dans la bougie.
# 70 signifie que le close doit être dans les 30% supérieurs de la bougie.
BREAKOUT_MIN_CLOSE_POSITION_PERCENT=70.0

# Taille minimale de la bougie en % de son open.
BREAKOUT_MIN_CANDLE_RANGE_PERCENT=0.05

# Si true, exige une tendance haussière via moyennes mobiles.
BREAKOUT_REQUIRE_UPTREND=false
BREAKOUT_TREND_FAST_LOOKBACK=5
BREAKOUT_TREND_SLOW_LOOKBACK=15


# ============================================================
# 5) Stratégie intraday_trend
# ============================================================
# Cette section n'a d'impact que si INVESTMENT_STRATEGY=intraday_trend.

# Nombre de bougies du petit range utilisé pour détecter breakout/breakdown.
INTRADAY_TREND_LOOKBACK=3

# Moyennes mobiles rapide/lente pour confirmer la tendance.
INTRADAY_TREND_FAST_LOOKBACK=5
INTRADAY_TREND_SLOW_LOOKBACK=15

# Fenêtre utilisée pour mesurer le mouvement de session.
INTRADAY_TREND_SESSION_LOOKBACK=20

# Mouvement minimum de session pour considérer que le marché a une direction.
INTRADAY_TREND_MIN_SESSION_MOVE_PERCENT=0.25

# Cassure minimale au-dessus/au-dessous du range récent.
INTRADAY_TREND_MIN_BREAKOUT_PERCENT=0.06

# Bougie trop petite = signal ignoré.
INTRADAY_TREND_MIN_CANDLE_RANGE_PERCENT=0.04

# Pour BUY, exige une clôture proche du high.
# Pour SELL, exige une clôture proche du low.
INTRADAY_TREND_MIN_CLOSE_POSITION_PERCENT=75.0

# Autorise la stratégie à produire des signaux SELL.
INTRADAY_TREND_ALLOW_SHORT=false

# Fenêtre ATR utilisée par la stratégie pour mesurer la volatilité réelle.
INTRADAY_TREND_ATR_LOOKBACK=14


# ============================================================
# 6) US-18 — Market regime filter
# ============================================================
# Objectif: éviter de trader les marchés morts, en range ou trop bruités.

# Active le filtre de régime. Si false, le régime est journalisé mais ne bloque pas.
INTRADAY_TREND_MARKET_REGIME_FILTER_ENABLED=false

# Trend strength minimum pour accepter TRENDING.
# Plus haut = filtre plus strict, moins de trades.
INTRADAY_TREND_MARKET_REGIME_MIN_TREND_STRENGTH_PERCENT=0.02

# ATR minimum. Si ATR trop faible => DEAD_MARKET.
INTRADAY_TREND_MARKET_REGIME_MIN_ATR_PERCENT=0.0

# ATR maximum. Si ATR trop haut => VOLATILE_NOISY.
# 0 désactive ce plafond.
INTRADAY_TREND_MARKET_REGIME_MAX_ATR_PERCENT=0.0

# Bruit maximum: ATR / mouvement de session.
# Plus bas = rejette davantage les mouvements chaotiques.
# 0 désactive ce filtre.
INTRADAY_TREND_MARKET_REGIME_MAX_NOISE_RATIO=0.0


# ============================================================
# 7) US-19 — Pré-scan dynamique des opportunités
# ============================================================
# Objectif: après détection des candidats, garder seulement les meilleurs terrains.
# Ce filtre agit AVANT l'évaluation finale du RiskManager.

# Active le pré-scan.
PRE_SCAN_ENABLED=false

# Garde seulement les N meilleurs candidats après scoring.
# 0 = pas de limite.
PRE_SCAN_TOP_N=0

# Score candidat minimum.
# Plus haut = moins de trades mais signaux plus sélectifs.
PRE_SCAN_MIN_SCORE=0.0

# Régimes acceptés. Si vide, ne filtre pas par régime.
# Exemple recommandé si US-18 actif: TRENDING
PRE_SCAN_ALLOWED_MARKET_REGIMES=TRENDING

# Spread maximum autorisé au niveau pré-scan.
# 0 = désactivé. Attention: il y a aussi les filtres de spread par asset class.
PRE_SCAN_MAX_SPREAD_PERCENT=0.0

# Mouvement de session minimum au niveau pré-scan.
PRE_SCAN_MIN_SESSION_MOVE_PERCENT=0.0

# Force de tendance minimum au niveau pré-scan.
PRE_SCAN_MIN_TREND_STRENGTH_PERCENT=0.0

# ATR min/max au niveau pré-scan.
# Pratique pour ignorer les actifs morts ou excessivement violents.
PRE_SCAN_MIN_ATR_PERCENT=0.0
PRE_SCAN_MAX_ATR_PERCENT=0.0

# Bruit maximum au niveau pré-scan.
# 0 = désactivé.
PRE_SCAN_MAX_NOISE_RATIO=0.0


# ============================================================
# 8) Limites globales de risque
# ============================================================

# Stratégie de sizing. Valeur connue: fixed_percent.
RISK_STRATEGY=fixed_percent

# Nombre maximum de positions ouvertes en même temps.
MAX_OPEN_POSITIONS=2

# Nombre maximum de positions ouvertes sur le même symbole.
MAX_OPEN_POSITIONS_PER_SYMBOL=1

# Nombre maximum de trades ouverts par jour.
# Les positions restaurées au redémarrage ne comptent pas comme nouveaux trades.
MAX_TRADES_PER_DAY=4

# Fallback global si le symbole n'est pas classé dans CRYPTO/EQUITY_US/EQUITY_EU.
MAX_POSITION_SIZE_PERCENT=0.75
STOP_LOSS_PERCENT=1.00
TAKE_PROFIT_PERCENT=2.00
ESTIMATED_ROUND_TRIP_FEES=0.00
MIN_EXPECTED_NET_PROFIT=0.00
MAX_SPREAD_PERCENT=0.00
MIN_MOVE_SPREAD_RATIO=0.00

# Force-close fallback pour asset class UNKNOWN.
FORCE_CLOSE_HOUR=23
FORCE_CLOSE_MINUTE=59


# ============================================================
# 9) SL/TP dynamiques basés sur ATR — fallback global
# ============================================================
# Si actif, remplace STOP_LOSS_PERCENT/TAKE_PROFIT_PERCENT par ATR × multiplicateur.

DYNAMIC_SL_TP_ENABLED=false
STOP_LOSS_ATR_MULTIPLIER=1.5
TAKE_PROFIT_ATR_MULTIPLIER=2.5

# Bornes de sécurité. 0 = borne désactivée.
MIN_STOP_LOSS_PERCENT=0.0
MAX_STOP_LOSS_PERCENT=0.0
MIN_TAKE_PROFIT_PERCENT=0.0
MAX_TAKE_PROFIT_PERCENT=0.0


# ============================================================
# 10) US-16 / US-17 — Break-even et trailing stop côté bot
# ============================================================
# Ces stops sont gérés par le bot tant qu'il tourne.
# Ils ne modifient pas encore le stop côté eToro après ouverture.

# Break-even: remonte le stop vers le prix d'entrée après un gain minimum.
BREAKEVEN_STOP_ENABLED=false
BREAKEVEN_TRIGGER_PERCENT=1.0
BREAKEVEN_BUFFER_PERCENT=0.0

# Trailing stop: fait suivre le stop derrière le meilleur prix atteint.
TRAILING_STOP_ENABLED=false
TRAILING_STOP_TRIGGER_PERCENT=1.5
TRAILING_STOP_DISTANCE_PERCENT=0.8


# ============================================================
# 11) Classification des actifs
# ============================================================
# Indispensable pour appliquer les bons profils de risque.
# Les symboles non listés tombent dans UNKNOWN et utilisent les paramètres globaux.

CRYPTO_SYMBOLS=BTC,ETH,DOGE,SOL,XRP,ADA,LTC
EQUITY_US_SYMBOLS=MSFT,NVDA,AAPL,AMZN,META,GOOGL,TSLA
EQUITY_EU_SYMBOLS=AIR.PA,SAF.PA


# ============================================================
# 12) Profil de risque crypto
# ============================================================
# Crypto: ouvert 24/7, spread parfois élevé, volatilité plus large.

CRYPTO_MAX_POSITION_SIZE_PERCENT=0.75
CRYPTO_STOP_LOSS_PERCENT=1.50
CRYPTO_TAKE_PROFIT_PERCENT=3.00
CRYPTO_ESTIMATED_ROUND_TRIP_FEES=3.00
CRYPTO_MIN_EXPECTED_NET_PROFIT=8.00
CRYPTO_FORCE_CLOSE_ENABLED=false
CRYPTO_FORCE_CLOSE_HOUR=23
CRYPTO_FORCE_CLOSE_MINUTE=59
CRYPTO_MAX_SPREAD_PERCENT=0.35
CRYPTO_MIN_MOVE_SPREAD_RATIO=4.0
CRYPTO_DYNAMIC_SL_TP_ENABLED=false
CRYPTO_STOP_LOSS_ATR_MULTIPLIER=1.5
CRYPTO_TAKE_PROFIT_ATR_MULTIPLIER=2.5
CRYPTO_MIN_STOP_LOSS_PERCENT=0.8
CRYPTO_MAX_STOP_LOSS_PERCENT=2.5
CRYPTO_MIN_TAKE_PROFIT_PERCENT=1.5
CRYPTO_MAX_TAKE_PROFIT_PERCENT=5.0


# ============================================================
# 13) Profil de risque actions US
# ============================================================
# Actions US: horaires de marché, spread souvent plus bas, force close utile.

EQUITY_US_MAX_POSITION_SIZE_PERCENT=0.75
EQUITY_US_STOP_LOSS_PERCENT=0.90
EQUITY_US_TAKE_PROFIT_PERCENT=1.60
EQUITY_US_ESTIMATED_ROUND_TRIP_FEES=2.50
EQUITY_US_MIN_EXPECTED_NET_PROFIT=5.00
EQUITY_US_FORCE_CLOSE_ENABLED=true
EQUITY_US_FORCE_CLOSE_HOUR=21
EQUITY_US_FORCE_CLOSE_MINUTE=55
EQUITY_US_MAX_SPREAD_PERCENT=0.10
EQUITY_US_MIN_MOVE_SPREAD_RATIO=3.0
EQUITY_US_DYNAMIC_SL_TP_ENABLED=false
EQUITY_US_STOP_LOSS_ATR_MULTIPLIER=1.2
EQUITY_US_TAKE_PROFIT_ATR_MULTIPLIER=2.0
EQUITY_US_MIN_STOP_LOSS_PERCENT=0.4
EQUITY_US_MAX_STOP_LOSS_PERCENT=1.5
EQUITY_US_MIN_TAKE_PROFIT_PERCENT=0.8
EQUITY_US_MAX_TAKE_PROFIT_PERCENT=3.0


# ============================================================
# 14) Profil de risque actions EU
# ============================================================
# Actions EU: horaires de marché différents, force close plus tôt.

EQUITY_EU_MAX_POSITION_SIZE_PERCENT=0.75
EQUITY_EU_STOP_LOSS_PERCENT=0.80
EQUITY_EU_TAKE_PROFIT_PERCENT=1.40
EQUITY_EU_ESTIMATED_ROUND_TRIP_FEES=2.50
EQUITY_EU_MIN_EXPECTED_NET_PROFIT=5.00
EQUITY_EU_FORCE_CLOSE_ENABLED=true
EQUITY_EU_FORCE_CLOSE_HOUR=17
EQUITY_EU_FORCE_CLOSE_MINUTE=25
EQUITY_EU_MAX_SPREAD_PERCENT=0.15
EQUITY_EU_MIN_MOVE_SPREAD_RATIO=3.0
EQUITY_EU_DYNAMIC_SL_TP_ENABLED=false
EQUITY_EU_STOP_LOSS_ATR_MULTIPLIER=1.2
EQUITY_EU_TAKE_PROFIT_ATR_MULTIPLIER=2.0
EQUITY_EU_MIN_STOP_LOSS_PERCENT=0.4
EQUITY_EU_MAX_STOP_LOSS_PERCENT=1.5
EQUITY_EU_MIN_TAKE_PROFIT_PERCENT=0.8
EQUITY_EU_MAX_TAKE_PROFIT_PERCENT=3.0


# ============================================================
# 15) Short selling
# ============================================================

# Autorise le RiskManager à approuver des SELL.
SHORT_SELLING_ENABLED=false

# Levier short utilisé par le broker si applicable.
SHORT_LEVERAGE=1


# ============================================================
# 16) Bougies / journaux / persistence
# ============================================================

# Taille des bougies construites à partir des snapshots.
CANDLE_TIMEFRAME_SECONDS=60

# Log applicatif texte.
APP_LOG_PATH=data/logs/earendil.log

# Base SQLite de persistence des positions ouvertes.
# Ne pas supprimer ce fichier quand des positions broker sont ouvertes.
POSITION_STORE_PATH=data/earendil.sqlite

# Journal trading JSONL.
JOURNAL_PATH=data/logs/trades.jsonl

# Journal des snapshots marché.
MARKET_LOG_PATH=data/logs/market.jsonl

# Journal des bougies fermées.
CANDLE_JOURNAL_PATH=data/logs/candles.jsonl
