# ============================================================
# EÄRENDIL — .env.example
# ============================================================
# Copie ce fichier vers .env puis adapte les valeurs.
# Ce fichier ne contient que les paramètres actuellement lus par Settings.
# Les valeurs fines de stratégie et de risque sont portées par les profils internes.
# ============================================================

# ============================================================
# 1) Runtime
# ============================================================

# Broker utilisé:
# - paper       : simulation locale avec FakeBroker.
# - etoro_demo  : compte démo eToro.
# - etoro_live  : compte réel eToro, à éviter tant que la stratégie n'est pas validée.
BROKER=paper

# Niveau de logs: DEBUG, INFO, WARNING, ERROR.
LOG_LEVEL=INFO

# Délai entre deux boucles complètes du bot.
# Plus bas = plus réactif, mais plus d'appels API.
POLL_INTERVAL_SECONDS=60

# Taille des bougies construites par le bot.
CANDLE_TIMEFRAME_SECONDS=60


# ============================================================
# 2) Broker / API eToro
# ============================================================

ETORO_API_KEY=replace_me
ETORO_USER_KEY=replace_me


# ============================================================
# 3) Univers de trading
# ============================================================

# Liste des actifs analysés à chaque boucle.
WATCHLIST=BTC,ETH,DOGE,SOL,MSFT,NVDA,AAPL

# Devise utilisée dans les payloads d'ordre eToro.
BASE_CURRENCY=USD

# Profil de stratégie unique:
# - balanced   : filtres plus stricts, moins de signaux.
# - aggressive : filtres plus permissifs, plus de signaux.
STRATEGY_AGGRESSIVENESS=balanced

# Active un fallback EU très contrôlé: TP/SL 0.6% brut pour les signaux EQUITY_EU
# forts mais pénalisés par le TP fixe normal de 1.0%.
EU_MICRO_SCALP_FALLBACK_ENABLED=false

# Classification des actifs utilisée pour choisir les profils internes.
# Chaque symbole de WATCHLIST doit appartenir à exactement une catégorie.
# Un symbole absent ou déclaré dans plusieurs catégories provoque un arrêt au démarrage.
CRYPTO_SYMBOLS=BTC,ETH,DOGE,SOL,XRP,ADA,LTC
EQUITY_US_SYMBOLS=MSFT,NVDA,AAPL,AMZN,META,GOOGL,TSLA
EQUITY_EU_SYMBOLS=AIR.PA,SAF.PA


# ============================================================
# 4) Limites globales de risque
# ============================================================

MAX_OPEN_POSITIONS=2
MAX_OPEN_POSITIONS_PER_SYMBOL=1
MAX_TRADES_PER_SESSION=4


# ============================================================
# 5) Journaux / persistence
# ============================================================

APP_LOG_PATH=data/logs/earendil.log
POSITION_STORE_PATH=data/earendil.sqlite
JOURNAL_PATH=data/logs/trades.jsonl
MARKET_LOG_PATH=data/logs/market.jsonl
CANDLE_JOURNAL_PATH=data/logs/candles.jsonl
