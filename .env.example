# ============================================================
# GOBLIN! — .env.example
# ============================================================
# Copy this file to .env, then adapt the values.
# Only runtime settings read by app.config.settings.Settings live here.
# Fine-grained strategy and risk values are versioned in the internal profiles.
# ============================================================

# ============================================================
# 1) Runtime
# ============================================================

# paper | etoro_demo | etoro_live
# Keep paper or etoro_demo until the strategy has been validated over enough runs.
BROKER=paper

# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Delay between two complete market polling loops.
POLL_INTERVAL_SECONDS=60

# Candle size built from market snapshots.
CANDLE_TIMEFRAME_SECONDS=60

# Aggregated human-readable heartbeat interval.
RUNTIME_HEARTBEAT_MINUTES=5


# ============================================================
# 2) eToro API
# ============================================================

ETORO_API_KEY=replace_me
ETORO_USER_KEY=replace_me

# Extra safety margin applied to short-position stop-loss payloads.
ETORO_SELLSHORT_SAFETY_SL_BUFFER_PERCENT=0.30


# ============================================================
# 3) Trading and context universe
# ============================================================

# Symbols eligible for trading.
WATCHLIST=BTC,ETH,DOGE,SOL,MSFT,NVDA,AAPL

# Currency sent in eToro order payloads.
BASE_CURRENCY=USD

# Every WATCHLIST symbol must belong to exactly one asset class.
# Missing or duplicated classifications fail fast at startup.
CRYPTO_SYMBOLS=BTC,ETH,DOGE,SOL,XRP,ADA,LTC
EQUITY_US_SYMBOLS=MSFT,NVDA,AAPL,AMZN,META,GOOGL,TSLA
EQUITY_EU_SYMBOLS=AIR.PA,SAF.PA

# Optional context-only benchmark symbols. They are never eligible for orders.
# Keep them empty until the exact broker alias has been verified for the account.
MARKET_BENCHMARK_CRYPTO=
MARKET_BENCHMARK_EQUITY_US=
MARKET_BENCHMARK_EQUITY_EU=


# ============================================================
# 4) Trading sessions
# ============================================================

# IANA timezone used to interpret the session windows below.
TRADING_SESSION_TIMEZONE=Europe/Paris

# Comma-separated HH:MM-HH:MM windows. An empty value means 24/7.
TRADING_SESSIONS_CRYPTO=
TRADING_SESSIONS_EQUITY_US=15:30-22:00
TRADING_SESSIONS_EQUITY_EU=09:00-17:30


# ============================================================
# 5) Global risk limits
# ============================================================

MAX_OPEN_POSITIONS=2
MAX_OPEN_POSITIONS_PER_SYMBOL=1
MAX_TRADES_PER_SESSION=4


# ============================================================
# 6) Journals and persistence
# ============================================================

APP_LOG_PATH=data/logs/goblin.log
POSITION_STORE_PATH=data/goblin.sqlite
JOURNAL_PATH=data/logs/trades.jsonl
ERRORS_JOURNAL_PATH=data/logs/errors.jsonl
MARKET_LOG_PATH=data/logs/market.jsonl.gz
CANDLE_JOURNAL_PATH=data/logs/candles.jsonl.gz
DEBUG_DECISIONS_JOURNAL_PATH=data/logs/debug_decisions.jsonl.gz
DAILY_SUMMARY_PATH=data/logs/daily_summary.json
PARTIAL_DAILY_SUMMARY_PATH=data/logs/daily_summary.partial.json
RUN_MANIFEST_PATH=data/logs/run_manifest.json

# minimal | normal | debug | full
JOURNAL_DETAIL_LEVEL=normal

# Keep the compressed per-decision stream only when deep diagnosis is needed.
JOURNAL_KEEP_DEBUG_DECISIONS=false

# Periodically refresh daily_summary.partial.json while the bot is running.
JOURNAL_WRITE_PARTIAL_SUMMARY=true
JOURNAL_PARTIAL_SUMMARY_INTERVAL_MINUTES=15
