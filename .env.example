# Runtime
EAR_MODE=paper
REAL_TRADING_ENABLED=false
LOG_LEVEL=INFO
POLL_INTERVAL_SECONDS=60

# Broker
BROKER=etoro
ETORO_ENV=demo
ETORO_API_BASE_URL=https://public-api.etoro.com
ETORO_API_KEY=replace_me
ETORO_USER_KEY=replace_me

# Trading
DEFAULT_SYMBOL=AAPL
WATCHLIST=AAPL,MSFT,AMZN,BTC,ETH,DOGE
BASE_CURRENCY=USD
MAX_OPEN_POSITIONS=1
MAX_TRADES_PER_DAY=3
MAX_OPEN_POSITIONS_PER_SYMBOL=1
RISK_PER_TRADE_PERCENT=1.0
MAX_POSITION_SIZE_PERCENT=20.0
STOP_LOSS_PERCENT=0.8
TAKE_PROFIT_PERCENT=1.2
FORCE_CLOSE_HOUR=21
FORCE_CLOSE_MINUTE=55
ESTIMATED_ROUND_TRIP_FEES=0.0
MIN_EXPECTED_NET_PROFIT=0.0

# Asset-class classification
CRYPTO_SYMBOLS=BTC,ETH,DOGE
EQUITY_US_SYMBOLS=AAPL,MSFT,AMZN
EQUITY_EU_SYMBOLS=

# Crypto risk profile
CRYPTO_MAX_POSITION_SIZE_PERCENT=0.75
CRYPTO_STOP_LOSS_PERCENT=1.50
CRYPTO_TAKE_PROFIT_PERCENT=3.00
CRYPTO_ESTIMATED_ROUND_TRIP_FEES=3.00
CRYPTO_MIN_EXPECTED_NET_PROFIT=8.00
CRYPTO_FORCE_CLOSE_ENABLED=false
CRYPTO_FORCE_CLOSE_HOUR=23
CRYPTO_FORCE_CLOSE_MINUTE=59

# US equities risk profile
EQUITY_US_MAX_POSITION_SIZE_PERCENT=0.75
EQUITY_US_STOP_LOSS_PERCENT=0.90
EQUITY_US_TAKE_PROFIT_PERCENT=1.60
EQUITY_US_ESTIMATED_ROUND_TRIP_FEES=2.50
EQUITY_US_MIN_EXPECTED_NET_PROFIT=5.00
EQUITY_US_FORCE_CLOSE_ENABLED=true
EQUITY_US_FORCE_CLOSE_HOUR=21
EQUITY_US_FORCE_CLOSE_MINUTE=55

# EU equities risk profile
EQUITY_EU_MAX_POSITION_SIZE_PERCENT=0.75
EQUITY_EU_STOP_LOSS_PERCENT=0.80
EQUITY_EU_TAKE_PROFIT_PERCENT=1.40
EQUITY_EU_ESTIMATED_ROUND_TRIP_FEES=2.50
EQUITY_EU_MIN_EXPECTED_NET_PROFIT=5.00
EQUITY_EU_FORCE_CLOSE_ENABLED=true
EQUITY_EU_FORCE_CLOSE_HOUR=17
EQUITY_EU_FORCE_CLOSE_MINUTE=25

BREAKOUT_REQUIRE_GREEN_CANDLE=true
BREAKOUT_MIN_CLOSE_POSITION_PERCENT=70.0
BREAKOUT_MIN_CANDLE_RANGE_PERCENT=0.05

BREAKOUT_REQUIRE_UPTREND=false
BREAKOUT_TREND_FAST_LOOKBACK=5
BREAKOUT_TREND_SLOW_LOOKBACK=15

# Storage
APP_LOG_PATH=data/logs/earendil.log
POSITION_STORE_PATH=data/earendil.sqlite
JOURNAL_PATH=data/logs/trades.jsonl
MARKET_LOG_PATH=data/logs/market.jsonl
CANDLE_JOURNAL_PATH=data/logs/candles.jsonl
