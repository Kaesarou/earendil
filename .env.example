# ============================================================
# GOBLIN! — .env.example
# ============================================================
# Copy this file to .env, then adapt the values.
# Only runtime settings read by app.config.settings.Settings live here.
# Fine-grained strategy and risk values are versioned in internal profiles.
# Candle durations are fixed in code: M1, M5, M15, M30 and H1.
# ============================================================

# 1) Runtime
# paper | etoro_demo | etoro_live
BROKER=paper
LOG_LEVEL=INFO

# Polling remains the paper-mode source and the explicit eToro fallback mode.
POLL_INTERVAL_SECONDS=10
RUNTIME_HEARTBEAT_MINUTES=5

# 2) Market Data V2
# auto | websocket | polling
# auto selects WebSocket for eToro and polling for paper.
MARKET_DATA_MODE=auto
MARKET_DATA_QUEUE_CAPACITY=4096
WS_POSITION_SILENCE_SECONDS=15
WS_GLOBAL_SILENCE_SECONDS=15
REST_CONTROL_INTERVAL_SECONDS=60
REST_CONTROL_ANOMALY_PERCENT=0.25
POSITION_FALLBACK_INTERVAL_SECONDS=10
DECISION_WINDOW_GRACE_SECONDS=5

# M1 closes from the UTC runtime clock. M5/M15/M30/H1 are then finalized from
# those canonical M1 bars at their own boundaries.
CANDLE_CLOCK_GRACE_SECONDS=1
CANDLE_MAX_CARRY_FORWARD_AGE_SECONDS=180
CANDLE_ORDERING_DROP_DEGRADE_COUNT=3
CANDLE_ORDERING_DROP_DEGRADE_RATIO=0.10

# A fresh position cannot disappear after one eventually-consistent portfolio
# response. Three spaced absences are required after the opening grace period.
POSITION_RECONCILIATION_GRACE_SECONDS=30
POSITION_RECONCILIATION_REQUIRED_MISSES=3
POSITION_RECONCILIATION_MISS_INTERVAL_SECONDS=10
UNKNOWN_ORDER_LOOKUP_INTERVAL_SECONDS=15
UNKNOWN_ORDER_MAX_AGE_MINUTES=30

# 3) eToro API
ETORO_API_KEY=replace_me
ETORO_USER_KEY=replace_me
ETORO_SELLSHORT_SAFETY_SL_BUFFER_PERCENT=0.30
# Instrument IDs are immutable and persisted to avoid resolving every symbol
# again on each restart. Uncached searches are paced below the shared quota.
ETORO_INSTRUMENT_ID_CACHE_PATH=data/etoro_instrument_ids.json
ETORO_INSTRUMENT_RESOLUTION_MIN_INTERVAL_SECONDS=1.05

# 4) Trading and context universe
WATCHLIST=BTC,ETH,DOGE,SOL,MSFT,NVDA,AAPL
BASE_CURRENCY=USD
CRYPTO_SYMBOLS=BTC,ETH,DOGE,SOL,XRP,ADA,LTC
EQUITY_US_SYMBOLS=MSFT,NVDA,AAPL,AMZN,META,GOOGL,TSLA
EQUITY_EU_SYMBOLS=AIR.PA,SAF.PA
MARKET_BENCHMARK_CRYPTO=Crypto10
MARKET_BENCHMARK_EQUITY_US=SPX500
MARKET_BENCHMARK_EQUITY_EU=FRA40

# 5) Trading sessions
TRADING_SESSION_TIMEZONE=Europe/Paris
TRADING_SESSIONS_CRYPTO=
TRADING_SESSIONS_EQUITY_US=15:30-22:00
TRADING_SESSIONS_EQUITY_EU=09:00-17:30

# 6) Global risk limits
MAX_OPEN_POSITIONS=2
MAX_OPEN_POSITIONS_PER_SYMBOL=1
MAX_TRADES_PER_SESSION=4

# 7) Journals and persistence
APP_LOG_PATH=data/logs/goblin.log
POSITION_STORE_PATH=data/goblin.sqlite
# Base paths remain compatibility pointers. Runtime JSONL files are written as
# compressed streams under data/logs/runs/<run_id>/.
JOURNAL_PATH=data/logs/trades.jsonl
ERRORS_JOURNAL_PATH=data/logs/errors.jsonl
MARKET_LOG_PATH=data/logs/market.jsonl.gz
CANDLE_JOURNAL_PATH=data/logs/candles.jsonl.gz
DEBUG_DECISIONS_JOURNAL_PATH=data/logs/debug_decisions.jsonl.gz
DAILY_SUMMARY_PATH=data/logs/daily_summary.json
PARTIAL_DAILY_SUMMARY_PATH=data/logs/daily_summary.partial.json
RUN_MANIFEST_PATH=data/logs/run_manifest.json
JOURNAL_DETAIL_LEVEL=normal
JOURNAL_KEEP_DEBUG_DECISIONS=false
JOURNAL_WRITE_PARTIAL_SUMMARY=true
JOURNAL_PARTIAL_SUMMARY_INTERVAL_MINUTES=15
JOURNAL_MAX_RUNS=30
